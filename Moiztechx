<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moiz TechX - Tech Reviews & Tutorials</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #00d4ff;
            --bg-dark: #0a0e17;
            --bg-card: #0f172a;
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --border: rgba(0, 212, 255, 0.1);
        }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            overflow-x: hidden;
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-dark); }
        ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 3px; }

        /* Navbar */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: rgba(10, 14, 23, 0.9);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }
        .logo {
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .nav-links { display: flex; gap: 2rem; list-style: none; }
        .nav-links a {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }
        .nav-links a:hover { color: var(--primary); }
        .nav-cta {
            background: var(--primary);
            color: var(--bg-dark);
            padding: 0.6rem 1.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.9rem;
        }
        .mobile-menu { display: none; font-size: 1.5rem; cursor: pointer; }

        /* Hero */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 8rem 5% 4rem;
            background: linear-gradient(135deg, #0a0e17 0%, #0f172a 50%, #1e1b4b 100%);
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 500px;
            height: 500px;
            background: rgba(0, 212, 255, 0.1);
            border-radius: 50%;
            filter: blur(100px);
        }
        .hero-content { position: relative; z-index: 1; max-width: 800px; }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid rgba(0, 212, 255, 0.3);
            padding: 0.5rem 1.2rem;
            border-radius: 50px;
            font-size: 0.85rem;
            color: var(--primary);
            margin-bottom: 1.5rem;
        }
        .hero h1 {
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 1rem;
        }
        .hero h1 span { color: var(--primary); }
        .hero-subtitle {
            font-size: 1.1rem;
            color: var(--text-secondary);
            max-width: 500px;
            margin: 0 auto 2rem;
            line-height: 1.6;
        }
        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin-bottom: 2rem;
        }
        .stat-number { font-size: 2.2rem; font-weight: 800; color: var(--primary); }
        .stat-label { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; }
        .btn-primary {
            background: var(--primary);
            color: var(--bg-dark);
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin: 0.5rem;
        }
        .btn-secondary {
            background: transparent;
            color: var(--text-primary);
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            border: 2px solid var(--border);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin: 0.5rem;
        }

        /* Sections */
        section { padding: 5rem 5%; }
        .section-header { text-align: center; margin-bottom: 3rem; }
        .section-header h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 800; }
        .section-header h2 span { color: var(--primary); }
        .section-header p { color: var(--text-secondary); max-width: 500px; margin: 0.5rem auto; }

        /* About */
        .about { background: var(--bg-card); }
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
            max-width: 1000px;
            margin: 0 auto;
        }
        .about-image {
            width: 100%;
            aspect-ratio: 1;
            border-radius: 20px;
            background: linear-gradient(135deg, #7c3aed 0%, #00d4ff 100%);
            padding: 4px;
        }
        .about-image-inner {
            width: 100%;
            height: 100%;
            border-radius: 16px;
            background: var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .about-image-inner img { width: 90%; height: 90%; object-fit: cover; border-radius: 12px; }
        .about-text h3 { font-size: 1.8rem; font-weight: 800; margin-bottom: 1rem; }
        .about-text h3 span { color: var(--primary); }
        .about-text p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 1rem; }
        .about-features {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.8rem;
            margin-top: 1.5rem;
        }
        .feature-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.8rem;
            background: var(--bg-dark);
            border-radius: 10px;
            border: 1px solid var(--border);
        }
        .feature-item span { color: var(--primary); font-size: 1rem; }
        .feature-item { font-size: 0.85rem; font-weight: 600; }

        /* Videos */
        .videos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            max-width: 1000px;
            margin: 0 auto;
        }
        .video-card {
            background: var(--bg-card);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--border);
            text-decoration: none;
            display: block;
            transition: transform 0.3s;
        }
        .video-card:hover { transform: translateY(-5px); }
        .video-thumbnail {
            position: relative;
            aspect-ratio: 16/9;
            background: var(--bg-card-hover);
            overflow: hidden;
        }
        .video-thumbnail img { width: 100%; height: 100%; object-fit: cover; }
        .video-play-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .video-card:hover .video-play-overlay { opacity: 1; }
        .video-play-btn {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--bg-dark);
            font-size: 1.2rem;
        }
        .video-duration {
            position: absolute;
            bottom: 8px;
            right: 8px;
            background: rgba(0,0,0,0.8);
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            color: white;
        }
        .video-info { padding: 1rem; }
        .video-category {
            display: inline-block;
            background: rgba(0, 212, 255, 0.1);
            color: var(--primary);
            padding: 0.2rem 0.6rem;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }
        .video-title { font-size: 0.95rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem; }
        .video-meta { display: flex; gap: 1rem; color: var(--text-muted); font-size: 0.8rem; }

        /* Categories */
        .categories { background: var(--bg-card); }
        .categories-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            max-width: 800px;
            margin: 0 auto;
        }
        .category-card {
            background: var(--bg-dark);
            padding: 2rem 1rem;
            border-radius: 16px;
            text-align: center;
            border: 1px solid var(--border);
            transition: all 0.3s;
        }
        .category-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
        }
        .category-icon {
            width: 60px;
            height: 60px;
            border-radius: 16px;
            background: rgba(0, 212, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            font-size: 1.5rem;
        }
        .category-card h3 { font-size: 1.1rem; margin-bottom: 0.3rem; }
        .category-card p { color: var(--text-muted); font-size: 0.85rem; }

        /* CTA */
        .cta {
            background: linear-gradient(135deg, #0a0e17 0%, #1e1b4b 50%, #0f172a 100%);
            text-align: center;
            padding: 5rem 5%;
        }
        .cta h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 1rem; }
        .cta p { color: var(--text-secondary); margin-bottom: 1.5rem; }
        .btn-youtube {
            background: #ff0000;
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Footer */
        .footer {
            background: var(--bg-dark);
            padding: 3rem 5% 1.5rem;
            border-top: 1px solid var(--border);
        }
        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 2rem;
            max-width: 1000px;
            margin: 0 auto 2rem;
        }
        .footer-brand h3 { color: var(--primary); font-size: 1.5rem; margin-bottom: 0.5rem; }
        .footer-brand p { color: var(--text-muted); font-size: 0.9rem; }
        .social-links { display: flex; gap: 0.8rem; margin-top: 1rem; }
        .social-links a {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 1rem;
        }
        .footer-column h4 { font-size: 1rem; margin-bottom: 1rem; }
        .footer-column ul { list-style: none; }
        .footer-column ul li { margin-bottom: 0.5rem; }
        .footer-column ul li a { color: var(--text-muted); text-decoration: none; font-size: 0.9rem; }
        .footer-bottom { text-align: center; padding-top: 1.5rem; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 0.85rem; }

        /* Responsive */
        @media (max-width: 768px) {
            .nav-links, .nav-cta { display: none; }
            .mobile-menu { display: block; }
            .about-grid { grid-template-columns: 1fr; }
            .footer-grid { grid-template-columns: 1fr; }
            .hero-stats { gap: 1.5rem; }
            .about-features { grid-template-columns: 1fr; }
        }
    </style>
</head>
